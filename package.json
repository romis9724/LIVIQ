{
  "name": "liviq",
  "private": true,
  "version": "0.1.0",
  "description": "LIVIQ — 아파트 관리 AI 플랫폼 (검색·응대·요약 계층)",
  "packageManager": "pnpm@9.12.3",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "start": "turbo run start",
    "db:migrate": "pnpm --filter @liviq/db db:migrate",
    "generate:api-types": "pnpm --filter @liviq/api-types generate",
    "check:paths": "node scripts/check-context-paths.mjs",
    "e2e": "pnpm --filter @liviq/e2e test:e2e"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  }
}
