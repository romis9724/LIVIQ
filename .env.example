# LIVIQ 환경 변수 예시 (.env.example)
#
# 사용법: 이 파일을 `.env`로 복사해 값을 채운다. `.env`는 커밋 금지(.gitignore).
# 기본값은 infra/docker-compose.yml 로컬 스택과 정합한다(그대로 쓰면 로컬 기동 가능).
# 시크릿 실값은 절대 이 파일(.env.example)에 넣지 않는다 — placeholder만.
#
# 검증: env는 부팅 시 검증한다(Python=Pydantic Settings, 누락 시 즉시 실패 fail-closed).
# 각 변수 소유 패키지는 주석에 표기 — 소유 패키지가 자기 스키마로 검증한다(중복 검증 금지).

# ── DB (검증 소유: packages/db · liviq_db/config.py) ─────────────────────
# 필수. PostgreSQL 16 + pgvector. CREATE EXTENSION vector는 첫 마이그레이션에서.
DATABASE_URL=postgresql+asyncpg://liviq:liviq@localhost:15432/liviq

# ── Redis — 세션·캐시·arq 큐 겸용 (검증 소유: apps/api·apps/ai-worker) ────
# 필수. 서버 세션 저장 + 정확 캐시 + 워커 큐를 한 인스턴스가 겸한다(ADR-0011).
REDIS_URL=redis://localhost:6381

# ── API 환경·가드레일 (검증 소유: apps/api · app/config.py) ───────────────
# 전부 선택(기본값 있음). API_ENV=local이면 dev 헤더(X-Dev-*) 보조 인증 허용.
API_ENV=local
# RATE_LIMIT_USER_PER_MIN=10      # AI 질의 분당 상한(사용자별). 0=비활성
# RATE_LIMIT_TENANT_PER_MIN=100   # AI 질의 분당 상한(단지별). 0=비활성
# CACHE_TTL_S=3600                # AI 질의 정확 캐시 TTL 초. 0=캐시 비활성
# LLM_DAILY_TOKEN_BUDGET=0        # 단지 일일 토큰 예산(경고만). 0=비활성

# ── S3 호환 오브젝트 스토리지 (검증 소유: apps/api · apps/ai-worker) ──────
# 필수. 문서·업로드 파일 저장. 로컬은 minio(infra 호스트 포트 9002).
S3_ENDPOINT_URL=http://localhost:9002
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=liviq
# STORAGE_BACKEND=s3              # 선택. "memory"=인메모리(E2E/테스트, MinIO 미기동 환경)

# ── Neo4j — 시설 파생 그래프 (검증 소유: packages/ai-core graph/config.py) ─
# 필수(그래프 경로 사용 시). 노드 tenant_id 프로퍼티로 격리(ADR-0009).
NEO4J_URI=bolt://localhost:7688
NEO4J_USER=neo4j
NEO4J_PASSWORD=liviqlocal    # 로컬 기본값. 운영은 시크릿 매니저

# ── LLM 생성 모델 (검증 소유: packages/ai-core · ADR-0005) ────────────────
# 필수. OpenAI-호환 단일 엔드포인트. 프로바이더 교체는 env만으로(로컬 기본 Ollama).
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=llama3.1:8b        # 파일럿 확정 모델(H5-1, docs/09 §8.6)
# LLM_API_KEY=                # 선택. 외부 API 사용 시에만
# LLM_MAX_OUTPUT_TOKENS=1024  # 선택
# LLM_TIMEOUT_S=60            # 선택

# ── 임베딩 모델 (검증 소유: packages/ai-core · ADR-0005 보강) ──────────────
# 필수. 생성 모델과 분리 운영. bge-m3(1024, cosine) 고정 — 교체 = 전량 재색인.
EMBEDDING_BASE_URL=http://localhost:11434/v1
EMBEDDING_MODEL=bge-m3
# EMBEDDING_API_KEY=          # 선택. 외부 API 사용 시에만
# EMBEDDING_DIMENSIONS=1024   # 선택

# ── 인증 — Google OAuth(PKCE) + Redis 서버 세션 (검증 소유: apps/api · ADR-0011) ─
# 전부 선택 — 미설정 시 /auth/google/* 503(부팅은 성공). 콜백은 FastAPI가 PKCE로
# 처리하고 구글 토큰은 저장하지 않는다. 세션은 Redis 서버 세션(쿠키엔 세션 ID만).
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/auth/google/callback
# authorize/token 엔드포인트 오버라이드 — mock IdP(tests/e2e/mock-idp.mjs)·사설 IdP용.
# GOOGLE_OAUTH_AUTH_URL=http://localhost:9099/authorize
# GOOGLE_OAUTH_TOKEN_URL=http://localhost:9099/token

# ── PII 봉투 암호화 마스터 키(KEK) (검증 소유: apps/api · ADR-0010) ────────
# 필수. 32byte base64. tenant DEK를 감싼다(pii_vault 봉투 암호화).
# 주의: 유실 시 pii_vault 복구 불능 → 시크릿 매니저 + 오프라인 백업 필수(docs/09 §7).
#   생성 예: `openssl rand -base64 32`
PII_MASTER_KEY=generate-with-openssl-rand-base64-32

# ── 웹 연동 (검증 소유: apps/api) ─────────────────────────────────────────
# 선택(기본값 있음). credentials(세션 쿠키) CORS 허용 오리진 + OAuth 콜백 후 복귀 URL.
# WEB_ORIGINS=http://localhost:3000,http://localhost:3001
# WEB_BASE_URL=http://localhost:3000

# ── 웹 앱 (apps/web-resident · apps/web-admin) ────────────────────────────
# 선택(기본값 http://localhost:8000). Next.js 앱이 호출할 API 베이스 URL.
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
