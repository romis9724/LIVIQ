# LIVIQ 환경 변수 예시 (.env.example)
#
# 사용법: 이 파일을 `.env`로 복사해 값을 채운다. `.env`는 커밋 금지(.gitignore).
# 기본값은 infra/docker-compose.yml 로컬 스택과 정합한다(그대로 쓰면 로컬 기동 가능).
# 시크릿 실값은 절대 이 파일(.env.example)에 넣지 않는다 — placeholder만.
#
# 검증: env는 부팅 시 Zod로 검증한다(누락 시 즉시 실패). 각 변수 소유 패키지는
# 주석에 표기 — 소유 패키지가 자기 스키마로 검증한다(중복 검증 금지).

# ── DB (검증 소유: packages/db) ─────────────────────────────────────────
# 필수. PostgreSQL 16 + pgvector. CREATE EXTENSION vector는 첫 마이그레이션에서.
DATABASE_URL=postgresql+asyncpg://liviq:liviq@127.0.0.1:15432/liviq

# ── Redis — 세션·캐시·BullMQ 겸용 (검증 소유: apps/api · ADR-0011) ────────
# 필수. 서버 세션 저장 + 정확/의미 캐시 + 워커 큐를 한 인스턴스가 겸한다.
REDIS_URL=redis://127.0.0.1:6381

# ── S3 호환 오브젝트 스토리지 (검증 소유: apps/api) ───────────────────────
# 필수. 문서·업로드 파일 저장. 로컬은 minio(경로 스타일 강제).
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=liviq
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1          # 선택. minio는 임의값 허용(기본값)
S3_FORCE_PATH_STYLE=true     # 선택. minio는 true 필요(기본값)

# ── Neo4j — 시설 파생 그래프 (검증 소유: apps/ai-worker · packages/ai-core) ─
# 필수. 벡터 인덱스는 Neo4j 5.13+ 내장. 노드 tenant_id 프로퍼티로 격리(ADR-0009).
NEO4J_URL=bolt://localhost:7688
NEO4J_USER=neo4j
NEO4J_PASSWORD=liviqlocal    # 로컬 기본값. 운영은 시크릿 매니저

# ── LLM 생성 모델 (검증 소유: packages/ai-core · ADR-0005) ────────────────
# 필수. OpenAI-호환 단일 엔드포인트. 프로바이더 교체는 이 3개 env만으로.
# 로컬 기본은 Ollama. LLM_API_KEY는 self-hosted(Ollama·vLLM)면 선택.
LLM_BASE_URL=http://localhost:11434/v1
LLM_MODEL=llama3.1           # placeholder. 골든셋 비교로 선정(ADR-0005)
LLM_API_KEY=                 # 선택. 외부 API 사용 시에만

# ── 임베딩 모델 (검증 소유: packages/ai-core · ADR-0005 보강) ──────────────
# 필수. 생성 모델과 분리 운영. bge-m3(1024, cosine) 고정 — 교체 = 전량 재색인.
EMBEDDING_BASE_URL=http://localhost:11434/v1
EMBEDDING_MODEL=bge-m3

# ── 인증 — Google OAuth + 서버 세션 (검증 소유: apps/api · ADR-0011) ───────
# 필수. 콜백은 NestJS가 PKCE로 처리, 구글 토큰 미저장.
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
OAUTH_CALLBACK_URL=http://localhost:3000/api/auth/callback/google
SESSION_SECRET=change-me-32+bytes-random   # 필수. 세션 쿠키 서명용 무작위값

# ── PII 봉투 암호화 마스터 키 (검증 소유: apps/api · ADR-0010) ─────────────
# 필수. 32byte base64. pii_vault 봉투 암호화의 KEK.
# 주의: 유실 시 pii_vault 복구 불능 → 시크릿 매니저 + 오프라인 백업 필수(docs/09 §7).
#   생성 예: `openssl rand -base64 32`
PII_MASTER_KEY=generate-with-openssl-rand-base64-32

MinIO http://localhost:9002
